# Copy this file to .env, then replace every REPLACE value before production use.
NODE_ENV=production
SUB2API_BASE_URL=https://sub2api.example.com
# Deliberately invalid placeholder. Replace with a server-side key using the admin- prefix.
SUB2API_ADMIN_API_KEY=REPLACE_ME
APP_ORIGIN=https://balance.example.com
SUB2API_ORIGIN=https://sub2api.example.com
# Deliberately short placeholders. Generate two independent values of at least 32 bytes.
SESSION_SECRET=REPLACE_ME
OPERATION_SIGNING_SECRET=REPLACE_ME
PORT=3000
OPERATION_TTL_MINUTES=60
UPSTREAM_TIMEOUT_MS=10000
TRUST_PROXY=false
LOG_LEVEL=info
COOKIE_SECURE=true
