# Copy this file to .env, then replace every REPLACE value before production use.
NODE_ENV=production
SUB2API_BASE_URL=https://sub2api.example.com
# Must be a server-side sub2api Admin API Key with the admin- prefix.
SUB2API_ADMIN_API_KEY=admin-REPLACE_WITH_SERVER_SIDE_ADMIN_API_KEY
APP_ORIGIN=https://balance.example.com
SUB2API_ORIGIN=https://sub2api.example.com
# Generate two independent random values of at least 32 bytes. Never reuse them.
SESSION_SECRET=REPLACE_WITH_INDEPENDENT_RANDOM_SESSION_SECRET
OPERATION_SIGNING_SECRET=REPLACE_WITH_INDEPENDENT_RANDOM_OPERATION_SECRET
PORT=3000
OPERATION_TTL_MINUTES=60
UPSTREAM_TIMEOUT_MS=10000
TRUST_PROXY=false
LOG_LEVEL=info
COOKIE_SECURE=true
